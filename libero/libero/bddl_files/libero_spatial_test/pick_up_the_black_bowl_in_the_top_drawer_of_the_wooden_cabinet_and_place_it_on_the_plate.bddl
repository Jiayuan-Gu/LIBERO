          (:target main_table)
          (:ranges (
              (0.1837 0.0269 0.2037 0.0469)
            )
          )
      )
      (cabinet_region
          (:target main_table)
          (:ranges (
              (0.0551 -0.2981 0.0751 -0.2781)
            )
          )
          (:yaw_rotation (
              (2.6613777765410678 2.7242096296128633)
            )
          )
      )
      (stove_region
          (:target main_table)
          (:ranges (
              (-0.4081 -0.1434 -0.3881 -0.1234)
            )
