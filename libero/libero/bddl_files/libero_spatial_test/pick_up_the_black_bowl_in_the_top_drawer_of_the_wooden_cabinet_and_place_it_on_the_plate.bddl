          (:ranges (
              (-0.2164 0.2162 -0.1964 0.2362)
            )
          )
      )
      (next_to_ramekin_region
          (:target main_table)
          (:ranges (
              (-0.1410 0.3547 -0.1210 0.3747)
            )
          )
      )
      (table_center
          (:target main_table)
          (:ranges (
              (-0.1424 0.0014 -0.0924 0.0214)
