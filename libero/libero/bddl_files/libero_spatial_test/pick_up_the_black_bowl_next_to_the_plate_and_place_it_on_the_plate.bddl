              (-0.0133 0.1586 0.0067 0.1786)
            )
          )
      )
      (ramekin_region
          (:target main_table)
          (:ranges (
              (-0.1608 0.2306 -0.1408 0.2506)
            )
          )
      )
      (next_to_ramekin_region
          (:target main_table)
          (:ranges (
              (-0.2210 0.3045 -0.2010 0.3245)
            )
          )
      )
      (table_center
          (:target main_table)
          (:ranges (
