      )
      (table_front
          (:target main_table)
          (:ranges (
              (0.1837 0.0120 0.2037 0.0320)
            )
          )
      )
      (cabinet_region
          (:target main_table)
          (:ranges (
              (0.0117 -0.2778 0.0317 -0.2578)
            )
          )
          (:yaw_rotation (
              (2.6613777765410678 2.7242096296128633)
            )
          )
      )
      (stove_region
          (:target main_table)
          (:ranges (
              (-0.3865 -0.1287 -0.3665 -0.1087)
            )
          )
      )
      (top_region
          (:target wooden_cabinet_1)
      )
      (middle_region
          (:target wooden_cabinet_1)
